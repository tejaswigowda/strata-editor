  "description": "jQuery for 3D — address and edit any three.js scene with CSS-like selectors, with deterministic auto-labelling and undoable ops.",
  "type": "module",
  "license": "MIT",
  "author": "Only Connect Labs",
  "homepage": "https://github.com/onlyconnect/3dom",
  "keywords": [
    "threejs",
    "three",
    "3d",
    "selectors",
    "scene-graph",
    "dom",
    "3dom",
    "query",
    "editor"
  ],
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "src",
    "dist",
    "SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test test/*.mjs"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "three": ">=0.150.0"
